<mujoco model="2R_robotic_arm"> 
    <compiler angle="radian" coordinate="local" />
    <option timestep="0.01" gravity="0 0 -9.81" />

    <worldbody>
        <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1" />
        <geom type="plane" size="1 1 0.1" rgba="0.9 0.9 0.9 1" />
        <!-- Base of robotic arm-->
        <body name="base" pos="0 0 0">
            <geom type="sphere" size="0.05" rgba="0.7 0.2 0.2 1" />
            <!-- First link-->
            <body name="link1" pos="0 0 0">
                <joint name="joint1" type="hinge" axis="0 0 1" range="-3.14159 3.14159" />
                <geom type="capsule" fromto="0 0 0 0.3 0 0" size="0.02" rgba="0.2 0.2 0.7 1" />

                <!-- Second link-->
                <body name="link2" pos="0.3 0 0">
                    <joint name="joint2" type="hinge" axis="0 0 1" range="-3.14159 3.14159" />
                    <geom type="capsule" fromto="0 0 0 0.3 0 0" size="0.02" rgba="0.2 0.7 0.2 1" />
                </body>
            </body>
        </body>   
    </worldbody>
 
    <actuator>
        <motor joint="joint1" ctrlrange="-50 50" />
        <motor joint="joint2" ctrlrange="-50 50" />
    </actuator>

</mujoco>